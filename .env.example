# Copy to `.env` for Astro tooling.
# For local Cloudflare runtime, copy the same values to `.dev.vars`.
# Production values belong in Cloudflare Worker secrets and GitHub Actions secrets.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-anon-key
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4.1-mini