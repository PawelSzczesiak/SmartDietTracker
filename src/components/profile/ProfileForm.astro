---
import type { ProfileRecord } from "@/lib/nutrition-records";

interface Props {
  profile: ProfileRecord | null;
}

const { profile } = Astro.props;
---

<form id="profile-form" method="POST" action="/api/profile" class="grid gap-4 md:grid-cols-2">
  <input type="hidden" name="previous_target_pace" value={profile?.target_pace ?? ""} />

  <label class="block text-sm text-blue-100/80">
    Age
    <input
      class="mt-1 w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/40 focus:border-purple-400 focus:outline-none"
      type="number"
      name="age"
      min="0"
      max="150"
      value={profile?.age ?? ""}
      placeholder="Optional"
    />
  </label>

  <label class="block text-sm text-blue-100/80">
    Sex
    <select
      name="sex"
      class="mt-1 w-full rounded-lg border border-white/20 bg-slate-950/40 px-3 py-2 text-white focus:border-purple-400 focus:outline-none"
    >
      <option value="">Optional</option>
      <option value="male" selected={profile?.sex === "male"}>Male</option>
      <option value="female" selected={profile?.sex === "female"}>Female</option>
    </select>
  </label>

  <label class="block text-sm text-blue-100/80">
    Current weight (kg)
    <input
      class="mt-1 w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/40 focus:border-purple-400 focus:outline-none"
      type="number"
      name="current_weight"
      min="0"
      step="0.01"
      value={profile?.current_weight ?? ""}
      placeholder="Optional"
    />
  </label>

  <label class="block text-sm text-blue-100/80">
    Height (cm)
    <input
      class="mt-1 w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/40 focus:border-purple-400 focus:outline-none"
      type="number"
      name="height"
      min="0"
      step="0.01"
      value={profile?.height ?? ""}
      placeholder="Optional"
    />
  </label>

  <label class="block text-sm text-blue-100/80">
    Target weight (kg)
    <input
      class="mt-1 w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/40 focus:border-purple-400 focus:outline-none"
      type="number"
      name="target_weight"
      min="0"
      step="0.01"
      value={profile?.target_weight ?? ""}
      placeholder="Optional"
    />
  </label>

  <fieldset class="md:col-span-2">
    <legend class="mb-2 text-sm text-blue-100/80">Target pace</legend>
    <div class="space-y-2">
      <label class="flex items-center gap-3">
        <input
          type="radio"
          name="target_pace"
          value="slow"
          checked={profile?.target_pace === "slow"}
          class="h-4 w-4 cursor-pointer rounded border-white/20 bg-white/10 text-purple-500 focus:ring-purple-400"
        />
        <span class="text-sm text-blue-100/80">Slow</span>
      </label>
      <label class="flex items-center gap-3">
        <input
          type="radio"
          name="target_pace"
          value="normal"
          checked={profile?.target_pace === "normal"}
          class="h-4 w-4 cursor-pointer rounded border-white/20 bg-white/10 text-purple-500 focus:ring-purple-400"
        />
        <span class="text-sm text-blue-100/80">Normal</span>
      </label>
      <label class="flex items-center gap-3">
        <input
          type="radio"
          name="target_pace"
          value="fast"
          checked={profile?.target_pace === "fast"}
          class="h-4 w-4 cursor-pointer rounded border-white/20 bg-white/10 text-purple-500 focus:ring-purple-400"
        />
        <span class="text-sm text-blue-100/80">Fast</span>
      </label>
    </div>
  </fieldset>

  <label class="block text-sm text-blue-100/80">
    Activity level
    <select
      name="activity_level"
      class="mt-1 w-full rounded-lg border border-white/20 bg-slate-950/40 px-3 py-2 text-white focus:border-purple-400 focus:outline-none"
    >
      <option value="low" selected={profile?.activity_level === "low"}>Low</option>
      <option value="normal" selected={profile?.activity_level === "normal" || !profile?.activity_level}>Normal</option>
      <option value="high" selected={profile?.activity_level === "high"}>High</option>
    </select>
  </label>

  <label class="block text-sm text-blue-100/80">
    Manual daily calorie limit
    <input
      class="mt-1 w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/40 focus:border-purple-400 focus:outline-none"
      type="number"
      name="manual_daily_calorie_limit"
      min="1"
      step="1"
      value={profile?.manual_daily_calorie_limit ?? ""}
      placeholder="Optional"
    />
  </label>

  <div class="flex justify-end md:col-span-2">
    <button
      type="submit"
      class="rounded-lg border border-white/20 bg-purple-500/80 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-purple-500"
    >
      Save profile
    </button>
  </div>
</form>
