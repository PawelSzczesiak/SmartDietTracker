---
interface Props {
  message: string;
  queryParam?: string;
}

const { message, queryParam = "profileToast" } = Astro.props;
---

<div
  class="fixed right-4 bottom-4 z-50 max-w-sm rounded-xl border border-emerald-400/30 bg-slate-950/95 px-4 py-3 text-sm text-emerald-50 shadow-2xl shadow-slate-950/40"
  role="status"
  aria-live="polite"
  data-query-param={queryParam}
>
  <div class="flex items-start gap-3">
    <div class="min-w-0 flex-1">
      <p class="font-semibold text-emerald-200">Profile updated</p>
      <p class="mt-1 text-emerald-50/90">{message}</p>
    </div>

    <button
      type="button"
      data-close-toast
      class="rounded-md border border-white/15 px-2 py-1 text-xs font-semibold text-white/80 transition-opacity hover:opacity-80"
      aria-label="Dismiss notification"
    >
      Close
    </button>
  </div>
</div>

<script is:inline>
  const toastRoot = document.currentScript?.previousElementSibling;

  if (toastRoot instanceof HTMLElement) {
    const closeToast = () => {
      toastRoot.remove();
    };

    const closeButton = toastRoot.querySelector("[data-close-toast]");
    if (closeButton instanceof HTMLButtonElement) {
      closeButton.addEventListener("click", closeToast);
    }

    const url = new URL(window.location.href);
    const queryParam = toastRoot.dataset.queryParam;
    if (queryParam) {
      url.searchParams.delete(queryParam);
    }
    history.replaceState(null, "", `${url.pathname}${url.search}${url.hash}`);

    window.setTimeout(closeToast, 4500);
  }
</script>
