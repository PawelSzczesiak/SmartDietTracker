---
interface Props {
  email?: string | null;
}

const { email } = Astro.props;
---

<div class="rounded-2xl border border-white/10 bg-white/10 p-6 backdrop-blur-xl">
  <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
    Dashboard
  </h1>
  <p class="mt-2 text-blue-100/80">
    Welcome, <span class="font-semibold text-white">{email}</span>
  </p>
  <p class="mt-1 text-sm text-blue-100/60">
    This is the first persisted app foundation: profile data and meal journal entries now live on your account.
  </p>
</div>
