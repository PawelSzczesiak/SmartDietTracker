---
import type { MealRecord } from "@/lib/nutrition-records";

interface Props {
  meals: MealRecord[];
}

const { meals } = Astro.props;
---

<div class="space-y-3">
  <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-100/60">Recent entries</h3>

  {
    meals.length > 0 ? (
      <ul class="space-y-3">
        {meals.map((meal) => (
          <li class="rounded-xl border border-white/10 bg-slate-950/30 px-4 py-3">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-medium text-white">{meal.meal_text}</p>
                <p class="mt-1 text-xs text-blue-100/60">Saved {new Date(meal.consumed_at).toLocaleString("en-GB")}</p>
              </div>
              <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-1 text-[11px] uppercase tracking-[0.16em] text-blue-100/50">
                Foundation
              </span>
            </div>
          </li>
        ))}
      </ul>
    ) : (
      <div class="rounded-xl border border-dashed border-white/15 bg-slate-950/20 px-4 py-6 text-sm text-blue-100/60">
        No meals saved yet. Your first entry will appear here after it is persisted.
      </div>
    )
  }
</div>
