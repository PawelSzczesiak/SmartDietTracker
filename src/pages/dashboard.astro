---
import DashboardHero from "@/components/dashboard/DashboardHero.astro";
import FlashMessage from "@/components/dashboard/FlashMessage.astro";
import FoodSuggestions from "@/components/dashboard/FoodSuggestions.astro";
import PacePromptBanner from "@/components/dashboard/PacePromptBanner.astro";
import ToastMessage from "@/components/dashboard/ToastMessage.astro";
import MealJournalSection from "@/components/meals/MealJournalSection.astro";
import ProfileSection from "@/components/profile/ProfileSection.astro";
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import { getDashboardFlashMessages } from "@/pages/dashboard/flash-messages";
import { getDailyCalorieWarning, getEffectiveDailyCalorieLimit, getTargetCaloriePolicy } from "@/lib/nutrition-goals";
import { getNutritionDayWindow } from "@/lib/nutrition-day";
import {
  getDailyMealSummary,
  getProfileForUser,
  listMealsForUserOnDay,
  listSuccessfulMealsForUser,
  type ProfileRecord,
  type MealRecord,
} from "@/lib/nutrition-records";
import {
  createRequestContext,
  logRequestDuration,
  logRequestEvent,
  startRequestSpan,
  startRequestTimer,
} from "@/lib/request-context";
import { getFoodSuggestionsForRemainingBudget } from "@/lib/services/food-suggestions";
import { createClient } from "@/lib/supabase";

const { user } = Astro.locals;
const requestContext = createRequestContext(Astro.request);
const dashboardLoadStartedAt = startRequestTimer();
const dayWindow = getNutritionDayWindow();
const supabase = createClient(Astro.request.headers, Astro.cookies);
const profileToast = Astro.url.searchParams.get("profileToast");
const loginToken = Astro.url.searchParams.get("login");

let dashboardError: string | null = null;
let profile: ProfileRecord | null = null;
let meals: MealRecord[] = [];
let successfulMeals: MealRecord[] = [];
let dailySummary = getDailyMealSummary([]);
let effectiveLimit = getEffectiveDailyCalorieLimit(null);
let calorieWarning = getDailyCalorieWarning(dailySummary, effectiveLimit);
let targetPolicy = getTargetCaloriePolicy(null, effectiveLimit);
let foodSuggestions = getFoodSuggestionsForRemainingBudget({
  calorieWarning,
  meals: successfulMeals,
});

if (user && supabase) {
  try {
    const dataFetchSpan = startRequestSpan(requestContext, "data_fetch", {
      category: "performance",
      operation: "dashboard.load",
    });
    const [loadedProfile, todaysMeals, allSuccessfulMeals] = await Promise.all([
      getProfileForUser(supabase, user.id),
      listMealsForUserOnDay(supabase, user.id, dayWindow),
      listSuccessfulMealsForUser(supabase, user.id),
    ]);
    dataFetchSpan.stop("info", "dashboard.load.span.completed", {
      userId: user.id,
    });

    profile = loadedProfile;
    meals = todaysMeals;
    successfulMeals = allSuccessfulMeals;
    dailySummary = getDailyMealSummary(todaysMeals);
    effectiveLimit = getEffectiveDailyCalorieLimit(profile);
    calorieWarning = getDailyCalorieWarning(dailySummary, effectiveLimit);
    targetPolicy = getTargetCaloriePolicy(profile, effectiveLimit);

    const suggestionsSpan = startRequestSpan(requestContext, "suggestions_compute", {
      category: "performance",
      operation: "dashboard.load",
    });
    foodSuggestions = getFoodSuggestionsForRemainingBudget({
      calorieWarning,
      meals: successfulMeals,
    });
    suggestionsSpan.stop("info", "dashboard.load.span.completed", {
      userId: user.id,
    });

    logRequestDuration("info", "dashboard.load.duration", requestContext, dashboardLoadStartedAt, {
      category: "performance",
      operation: "dashboard.load",
      outcome: "succeeded",
      userId: user.id,
    });
  } catch (error) {
    logRequestEvent("error", "dashboard.load.failed", requestContext, {
      category: "supabase",
      message: error instanceof Error ? error.message : "Unable to load dashboard data",
      userId: user.id,
    });
    logRequestDuration("error", "dashboard.load.duration", requestContext, dashboardLoadStartedAt, {
      category: "performance",
      operation: "dashboard.load",
      outcome: "failed",
      userId: user.id,
    });
    dashboardError = "Unable to load dashboard data";
  }
} else {
  logRequestDuration("info", "dashboard.load.duration", requestContext, dashboardLoadStartedAt, {
    category: "performance",
    operation: "dashboard.load",
    outcome: "skipped",
    hasUser: Boolean(user),
    hasSupabaseClient: Boolean(supabase),
  });
}

const flashMessages = getDashboardFlashMessages(Astro.url.searchParams, dashboardError);
---

<Layout title="Dashboard">
  <div class="bg-cosmic min-h-screen p-4 text-white">
    <div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
      <Topbar />

      {user?.id && profile?.target_pace == null && <PacePromptBanner sessionToken={loginToken} userId={user.id} />}

      <DashboardHero
        email={user?.email}
        summary={dailySummary}
        effectiveLimit={effectiveLimit}
        calorieWarning={calorieWarning}
        targetPolicy={targetPolicy}
      />

      <FoodSuggestions foodSuggestions={foodSuggestions} />

      {
        flashMessages.length > 0 && (
          <div class="space-y-3">
            {flashMessages.map((flash) => (
              <FlashMessage message={flash.message} prefix={flash.prefix} variant={flash.variant} />
            ))}
          </div>
        )
      }

      <div class="grid gap-6 lg:grid-cols-[1.1fr,0.9fr]">
        <ProfileSection profile={profile} targetPolicy={targetPolicy} />
        <MealJournalSection meals={meals} summary={dailySummary} calorieWarning={calorieWarning} />
      </div>

      {profileToast && <ToastMessage message={profileToast} />}
    </div>
  </div>
</Layout>
