---
import DashboardHero from "@/components/dashboard/DashboardHero.astro";
import FlashMessage from "@/components/dashboard/FlashMessage.astro";
import MealJournalSection from "@/components/meals/MealJournalSection.astro";
import ProfileSection from "@/components/profile/ProfileSection.astro";
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import { getProfileForUser, listMealsForUser } from "@/lib/nutrition-records";
import { createClient } from "@/lib/supabase";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);
const profileError = Astro.url.searchParams.get("profileError");
const profileSuccess = Astro.url.searchParams.get("profileSuccess");
const mealError = Astro.url.searchParams.get("mealError");
const mealSuccess = Astro.url.searchParams.get("mealSuccess");

let dashboardError: string | null = null;
let profile = null;
let meals = [];

if (user && supabase) {
  try {
    [profile, meals] = await Promise.all([getProfileForUser(supabase, user.id), listMealsForUser(supabase, user.id)]);
  } catch (error) {
    dashboardError = error instanceof Error ? error.message : "Unable to load dashboard data";
  }
}
---

<Layout title="Dashboard">
  <div class="bg-cosmic min-h-screen p-4 text-white">
    <div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
      <Topbar />

      <DashboardHero email={user?.email} />

      {
        (profileError || mealError || profileSuccess || mealSuccess || dashboardError) && (
          <div class="space-y-3">
            {dashboardError && <FlashMessage message={dashboardError} />}
            {profileError && <FlashMessage prefix="Profile" message={profileError} />}
            {mealError && <FlashMessage prefix="Meals" message={mealError} />}
            {profileSuccess && <FlashMessage message={profileSuccess} variant="success" />}
            {mealSuccess && <FlashMessage message={mealSuccess} variant="success" />}
          </div>
        )
      }

      <div class="grid gap-6 lg:grid-cols-[1.1fr,0.9fr]">
        <ProfileSection profile={profile} />
        <MealJournalSection meals={meals} />
      </div>
    </div>
  </div>
</Layout>
