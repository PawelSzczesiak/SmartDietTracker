---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import { getProfileForUser, listMealsForUser } from "@/lib/nutrition-records";
import { createClient } from "@/lib/supabase";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);
const profileError = Astro.url.searchParams.get("profileError");
const profileSuccess = Astro.url.searchParams.get("profileSuccess");
const mealError = Astro.url.searchParams.get("mealError");
const mealSuccess = Astro.url.searchParams.get("mealSuccess");

let dashboardError: string | null = null;
let profile = null;
let meals = [];

if (user && supabase) {
  try {
    [profile, meals] = await Promise.all([getProfileForUser(supabase, user.id), listMealsForUser(supabase, user.id)]);
  } catch (error) {
    dashboardError = error instanceof Error ? error.message : "Unable to load dashboard data";
  }
}
---

<Layout title="Dashboard">
  <div class="bg-cosmic min-h-screen p-4 text-white">
    <div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
      <Topbar />

      <div class="rounded-2xl border border-white/10 bg-white/10 p-6 backdrop-blur-xl">
        <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          Dashboard
        </h1>
        <p class="mt-2 text-blue-100/80">
          Welcome, <span class="font-semibold text-white">{user?.email}</span>
        </p>
        <p class="mt-1 text-sm text-blue-100/60">
          This is the first persisted app foundation: profile data and meal journal entries now live on your account.
        </p>
      </div>

      {
        (profileError || mealError || profileSuccess || mealSuccess || dashboardError) && (
          <div class="space-y-3">
            {dashboardError && (
              <div class="rounded-xl border border-red-400/40 bg-red-500/10 px-4 py-3 text-sm text-red-100">
                {dashboardError}
              </div>
            )}
            {profileError && (
              <div class="rounded-xl border border-red-400/40 bg-red-500/10 px-4 py-3 text-sm text-red-100">
                Profile: {profileError}
              </div>
            )}
            {mealError && (
              <div class="rounded-xl border border-red-400/40 bg-red-500/10 px-4 py-3 text-sm text-red-100">
                Meals: {mealError}
              </div>
            )}
            {profileSuccess && (
              <div class="rounded-xl border border-emerald-400/40 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-100">
                {profileSuccess}
              </div>
            )}
            {mealSuccess && (
              <div class="rounded-xl border border-emerald-400/40 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-100">
                {mealSuccess}
              </div>
            )}
          </div>
        )
      }

      <div class="grid gap-6 lg:grid-cols-[1.1fr,0.9fr]">
        <section class="rounded-2xl border border-white/10 bg-white/10 p-6 backdrop-blur-xl">
          <div class="mb-6">
            <h2 class="text-xl font-semibold text-white">Profile</h2>
            <p class="mt-1 text-sm text-blue-100/60">
              Save the core fields needed for the next calorie-tracking slice. Empty fields stay optional.
            </p>
          </div>

          <form method="POST" action="/api/profile" class="grid gap-4 md:grid-cols-2">
            <label class="block text-sm text-blue-100/80">
              Age
              <input
                class="mt-1 w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/40 focus:border-purple-400 focus:outline-none"
                type="number"
                name="age"
                min="0"
                max="150"
                value={profile?.age ?? ""}
                placeholder="Optional"
              />
            </label>

            <label class="block text-sm text-blue-100/80">
              Sex
              <select
                name="sex"
                class="mt-1 w-full rounded-lg border border-white/20 bg-slate-950/40 px-3 py-2 text-white focus:border-purple-400 focus:outline-none"
              >
                <option value="">Optional</option>
                <option value="male" selected={profile?.sex === "male"}>Male</option>
                <option value="female" selected={profile?.sex === "female"}>Female</option>
                <option value="other" selected={profile?.sex === "other"}>Other</option>
                <option value="prefer_not_to_say" selected={profile?.sex === "prefer_not_to_say"}>
                  Prefer not to say
                </option>
              </select>
            </label>

            <label class="block text-sm text-blue-100/80">
              Current weight (kg)
              <input
                class="mt-1 w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/40 focus:border-purple-400 focus:outline-none"
                type="number"
                name="current_weight"
                min="0"
                step="0.01"
                value={profile?.current_weight ?? ""}
                placeholder="Optional"
              />
            </label>

            <label class="block text-sm text-blue-100/80">
              Height (cm)
              <input
                class="mt-1 w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/40 focus:border-purple-400 focus:outline-none"
                type="number"
                name="height"
                min="0"
                step="0.01"
                value={profile?.height ?? ""}
                placeholder="Optional"
              />
            </label>

            <label class="block text-sm text-blue-100/80">
              Target weight (kg)
              <input
                class="mt-1 w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/40 focus:border-purple-400 focus:outline-none"
                type="number"
                name="target_weight"
                min="0"
                step="0.01"
                value={profile?.target_weight ?? ""}
                placeholder="Optional"
              />
            </label>

            <label class="block text-sm text-blue-100/80">
              Manual daily calorie limit
              <input
                class="mt-1 w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/40 focus:border-purple-400 focus:outline-none"
                type="number"
                name="manual_daily_calorie_limit"
                min="1"
                step="1"
                value={profile?.manual_daily_calorie_limit ?? ""}
                placeholder="Optional"
              />
            </label>

            <div class="md:col-span-2 flex justify-end">
              <button
                type="submit"
                class="rounded-lg border border-white/20 bg-purple-500/80 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-purple-500"
              >
                Save profile
              </button>
            </div>
          </form>
        </section>

        <section class="rounded-2xl border border-white/10 bg-white/10 p-6 backdrop-blur-xl">
          <div class="mb-6">
            <h2 class="text-xl font-semibold text-white">Meal journal</h2>
            <p class="mt-1 text-sm text-blue-100/60">
              Add free-form meal entries now; calorie and macro enrichment will come in later slices.
            </p>
          </div>

          <form method="POST" action="/api/meals" class="space-y-4">
            <label class="block text-sm text-blue-100/80">
              Meal description
              <textarea
                name="meal_text"
                rows="4"
                class="mt-1 w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/40 focus:border-purple-400 focus:outline-none"
                placeholder="e.g. 2 eggs, rye bread, cottage cheese"
              ></textarea>
            </label>

            <div class="flex justify-end">
              <button
                type="submit"
                class="rounded-lg border border-white/20 bg-purple-500/80 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-purple-500"
              >
                Add meal
              </button>
            </div>
          </form>

          <div class="mt-6 space-y-3">
            <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-100/60">Recent entries</h3>

            {
              meals.length > 0 ? (
                <ul class="space-y-3">
                  {meals.map((meal) => (
                    <li class="rounded-xl border border-white/10 bg-slate-950/30 px-4 py-3">
                      <p class="text-sm font-medium text-white">{meal.meal_text}</p>
                      <p class="mt-1 text-xs text-blue-100/60">
                        Saved {new Date(meal.consumed_at).toLocaleString("en-GB")}
                      </p>
                    </li>
                  ))}
                </ul>
              ) : (
                <div class="rounded-xl border border-dashed border-white/15 bg-slate-950/20 px-4 py-6 text-sm text-blue-100/60">
                  No meals saved yet. Your first entry will appear here after it is persisted.
                </div>
              )
            }
          </div>
        </section>
      </div>
    </div>
  </div>
</Layout>
